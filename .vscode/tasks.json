{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev (Cursor) :3001",
      "type": "shell",
      "command": "npm run dev:cursor",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting",
          "endsPattern": "ready"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
